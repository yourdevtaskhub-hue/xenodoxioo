// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== USERS ====================
model User {
  id                    String     @id @default(cuid())
  email                 String     @unique
  firstName             String
  lastName              String
  password              String
  role                  String     @default("CUSTOMER")
  status                String     @default("ACTIVE")
  isEmailVerified       Boolean    @default(false)
  emailVerificationToken String?
  passwordResetToken   String?
  passwordResetExpires  DateTime?
  lastLoginAt          DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  
  // Relations
  sessions              Session[]
  passwordResets        PasswordReset[]
  bookings              Booking[]
  payments              Payment[]
  reviews               Review[]
  adminLogs             AdminLog[]
}

// ==================== SESSIONS ====================
model Session {
  id                    String     @id @default(cuid())
  userId                String
  token                 String     @unique
  refreshToken           String     @unique
  expiresAt             DateTime
  createdAt             DateTime   @default(now())
  
  // Relations
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== PASSWORD RESETS ====================
model PasswordReset {
  id                    String     @id @default(cuid())
  userId                String
  token                 String     @unique
  expiresAt             DateTime
  createdAt             DateTime   @default(now())
  
  // Relations
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== PROPERTIES ====================
model Property {
  id                    String     @id @default(cuid())
  name                  String
  description           String
  location              String
  city                  String
  country               String
  slug                  String     @unique
  mainImage             String
  galleryImages         String     @default("[]")
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  
  // Relations
  units                 Unit[]
  amenities             Amenity[]
  dateBlockages         DateBlockage[]
  seasonalPricing       SeasonalPricing[]
}

// ==================== UNITS ====================
model Unit {
  id                    String     @id @default(cuid())
  propertyId            String
  name                  String
  slug                  String
  description           String?
  maxGuests            Int
  bedrooms             Int
  bathrooms            Int
  beds                 Int
  basePrice             Float
  cleaningFee           Float     @default(0)
  images                String     @default("[]")
  minStayDays           Int        @default(1)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  
  // Relations
  property              Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings              Booking[]
}

// ==================== BOOKINGS ====================
model Booking {
  id                    String     @id @default(cuid())
  bookingNumber         String     @unique
  unitId                String
  userId                String?    // null = guest checkout
  checkInDate           DateTime
  checkOutDate          DateTime
  nights                Int
  basePrice             Float
  totalNights           Int
  subtotal              Float
  cleaningFee           Float     @default(0)
  taxes                 Float     @default(0)
  discountAmount        Float     @default(0)
  depositAmount         Float     @default(0)
  balanceAmount         Float     @default(0)
  totalPrice            Float
  guests                Int
  guestName             String
  guestEmail            String
  guestPhone            String?
  totalPaid             Float     @default(0)
  paymentStatus          String     @default("PENDING")
  depositPaid            Boolean    @default(false)
  balancePaid           Boolean    @default(false)
  balanceChargeDate     DateTime?
  status                String     @default("PENDING")
  stripeCustomerId      String?
  cancellationReason   String?
  cancelledAt           DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  
  // Relations
  unit                  Unit       @relation(fields: [unitId], references: [id], onDelete: Cascade)
  user                  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  payments              Payment[]
  reviews               Review[]
}

// ==================== PAYMENTS ====================
model Payment {
  id                    String     @id @default(cuid())
  bookingId             String
  userId                String
  amount                Float
  currency              String     @default("EUR")
  paymentType           String
  stripePaymentIntentId String?
  stripeChargeId       String?
  stripeCustomerId      String?
  status                String     @default("PENDING")
  processedAt           DateTime?
  scheduledFor          DateTime?
  failureCount          Int        @default(0)
  lastError            String?
  description           String?
  isRefundable          Boolean    @default(true)
  refundAmount         Float     @default(0)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  
  // Relations
  booking               Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== REVIEWS ====================
model Review {
  id                    String     @id @default(cuid())
  bookingId             String
  userId                String
  rating                Int
  comment               String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  
  // Relations
  booking               Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ==================== ADMIN LOGS ====================
model AdminLog {
  id                    String     @id @default(cuid())
  adminId               String
  action                String
  entityType            String
  entityId              String?
  description           String?
  changes               String?
  createdAt             DateTime   @default(now())
  
  // Relations
  admin                 User       @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

// ==================== DATE BLOCKAGES ====================
model DateBlockage {
  id                    String     @id @default(cuid())
  propertyId            String
  startDate             DateTime
  endDate               DateTime
  reason                String?
  createdAt             DateTime   @default(now())
  
  // Relations
  property              Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ==================== SEASONAL PRICING ====================
model SeasonalPricing {
  id                    String     @id @default(cuid())
  propertyId            String
  name                  String
  startDate             DateTime
  endDate               DateTime
  pricePerNight         Float
  minStayDays           Int        @default(1)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  
  // Relations
  property              Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// ==================== COUPONS ====================
model Coupon {
  id                    String     @id @default(cuid())
  code                  String     @unique
  description           String?
  discountType          String     // PERCENTAGE or FIXED
  discountValue         Float
  validFrom             DateTime
  validUntil            DateTime
  minBookingAmount      Float?
  maxUses               Int?
  usedCount             Int        @default(0)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
}

// ==================== AMENITIES ====================
model Amenity {
  id                    String     @id @default(cuid())
  propertyId            String
  name                  String
  description           String?
  icon                  String?
  createdAt             DateTime   @default(now())
  
  // Relations
  property              Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}
